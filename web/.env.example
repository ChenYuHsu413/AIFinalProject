# Base URL of the FastAPI backend.
# - Dev: point at the local uvicorn server (see README §12). If port 8000 is
#   busy, start uvicorn on another port and update this.
# - Prod (GCP VM + nginx): set to the deployed origin, or "/api" and let nginx
#   reverse-proxy /api to uvicorn.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
