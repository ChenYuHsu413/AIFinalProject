# Byte-compiled / cache
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual envs
.venv/
venv/
env/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Project artefacts
outputs/models/*.joblib
outputs/models/*.pkl
outputs/figures/*.png
outputs/metrics/*.csv
outputs/metrics/*.json

# Runtime logs / scratch files written by the launchers
outputs/.streamlit.log
outputs/.fastapi.log
outputs/.batch_sample.csv
*.log

# Raw dataset (must be downloaded by the user)
data/raw/*.csv
data/processed/*.csv
data/processed/*.parquet
# Module Servo windowed raw-signal dataset (Phase B 1D-CNN) — transient offline
# artefact rebuilt from the raw zip; large, never commit (cloud reads only the JSON).
data/processed/*.npz
# IMS Set 2 raw snapshots (~1.5 GB, extensionless files) — never commit
data/raw/ims/
# XJTU-SY raw snapshots (Module B+, multi-bearing CSVs) — never commit
data/raw/xjtu/
# Paderborn raw snapshots (Module C, ~20 GB .mat files) — never commit
data/raw/paderborn/
# Module Servo raw PHM time-series CSV(s) — downloaded by the user, never commit
data/raw/servo/

# Module B (IMS) processed artefacts — small, committed so the live demo works
# without the 1.5 GB raw dataset (override the broad ignores above).
!data/processed/ims_set2_features.parquet
!outputs/metrics/ims_rul_predictions.csv
!outputs/metrics/ims_rul.json

# Module B+ (XJTU) processed artefacts — small, committed for reproducibility.
!data/processed/xjtu_features.parquet
!outputs/metrics/xjtu_generalization.csv
!outputs/metrics/xjtu_generalization.json
!outputs/metrics/xjtu_rul_predictions.csv
!outputs/metrics/xjtu_lobo.json
!outputs/metrics/xjtu_lobo_predictions.csv
!outputs/metrics/xjtu_loco.json
!outputs/metrics/xjtu_loco_predictions.csv

# Module C (Paderborn) processed artefacts — small, committed for reproducibility.
!data/processed/paderborn_features.parquet
!outputs/metrics/paderborn_eval.json
!outputs/metrics/paderborn_predictions.csv
!outputs/metrics/paderborn_domain_adapt.json
# ~0.8 MB classifier — committed so the cloud demo can do live inference.
!outputs/models/paderborn_clf.joblib

# Module Servo (main line) artefacts — committed so the cloud demo runs without
# the raw PHM dataset (placeholder data until the real dataset is downloaded).
!data/processed/servo_features.parquet
!data/processed/servo_feature_demo.csv
!data/processed/servo_sample_predictions.csv
!outputs/models/servo_clf.joblib
!outputs/models/servo_reg.joblib
!outputs/metrics/servo_clf_eval.json
!outputs/metrics/servo_reg_eval.json
!outputs/metrics/servo_dl_results.json
!outputs/metrics/servo_cnn_results.json
!outputs/metrics/servo_data_provenance.json

# Module A + comparison-study artefacts — committed so the dashboard's
# evaluation tab and the written report render without re-running training
# (override the broad ignores above). ims_rul.joblib stays ignored on purpose.
!outputs/models/best_model.joblib
!outputs/models/failure_type_model.joblib
!outputs/figures/*.png
!outputs/metrics/best_model_eval.json
!outputs/metrics/failure_type_comparison.csv
!outputs/metrics/feature_importance_native.csv
!outputs/metrics/feature_importance_permutation.csv
!outputs/metrics/model_comparison.csv
!outputs/metrics/test_predictions.csv

# EDA exploratory figures — regenerable via scripts/run_eda.py, not referenced
# by any web/streamlit page, so re-ignore them (overrides the broad un-ignore above)
outputs/figures/eda_*.png

# Keep folder placeholders
!**/.gitkeep

# Secrets / local env (LLM provider keys) — keep .env.example committed
.env

# Streamlit
.streamlit/secrets.toml
