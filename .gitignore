outputs/.fastapi.log
outputs/.batch_sample.csv
*.log

# Claude Code export transcripts (local only — may contain private context)
conversation-*.txt

# Raw dataset (must be downloaded by the user)
data/raw/*.csv
data/processed/*.csv
data/processed/*.parquet

# Keep folder placeholders
!**/.gitkeep

# Streamlit
.streamlit/secrets.toml
