# VCS / IDE / cache
.git
.gitignore
.github
.idea
.vscode
.pytest_cache
.ipynb_checkpoints
__pycache__
**/__pycache__
*.pyc
*.pyo

# Local virtual environments
.venv
venv
env

# Notebooks & tests are not needed at runtime
notebooks
tests
scripts

# Auto-generated runtime artefacts. For docker-compose these are volume-mounted
# (so excluded from the image), BUT the *committed* models / metrics / processed
# servo data must stay in the build context so the Hugging Face image
# (deploy/huggingface/Dockerfile, which has no volumes) can COPY them.
# See docs/DEPLOYMENT.md §9.
outputs/*
!outputs/models
!outputs/metrics
data/raw
data/processed/*
!data/processed/servo_features.parquet
!data/processed/servo_feature_demo.csv
!data/processed/servo_sample_predictions.csv
!data/processed/paderborn_features.parquet
!data/processed/xjtu_features.parquet

# Local logs
*.log
outputs/.streamlit.log
outputs/.fastapi.log
outputs/.batch_sample.csv

# Docker / CI artefacts themselves
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.yaml
