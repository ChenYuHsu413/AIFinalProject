# LLM 維護助理金鑰範本 —— 複製成 .env 後填入即可（.env 不會進 git）。
#   cp .env.example .env
#
# 只需填「任一家」免費供應商即可；助理會依 config.yaml::llm.providers 的順序
# 嘗試：Groq -> OpenRouter -> Gemini -> Anthropic，全部失敗才用離線範本。
# 留空的金鑰會被忽略。

# Groq（免費額度，速度快）        https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter（含多個 :free 模型）  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini（免費額度）        https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic（選用，非免費）        https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
